# Apex Operations — AI Email Triage
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is listed in .gitignore.

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# HubSpot Private App Token (starts with hsp_)
HUBSPOT_TOKEN=hsp_your-hubspot-token-here

# HubSpot Portal ID (found in HubSpot URL: app.hubspot.com/contacts/XXXXXXXX)
HUBSPOT_PORTAL_ID=your-portal-id-here

# Slack Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Shared upload secret — sent by the HTML form in the X-Upload-Secret header
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
UPLOAD_SECRET=your-long-random-secret-here
